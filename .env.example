# Required ─ your Azure subscription that uses the sponsorship offer
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Service-principal credentials (recommended for non-interactive / server use).
# Alternatively, set AZURE_CLIENT_CERTIFICATE_PATH or leave all three unset to
# fall back to DefaultAzureCredential (managed identity, az CLI, etc.).
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=<your-client-secret>

# RateCard settings (all optional – defaults shown)
# AZURE_OFFER_ID=MS-AZR-0036P
# AZURE_CURRENCY=USD
# AZURE_LOCALE=en-US
# AZURE_REGION_INFO=US

# Flask settings (optional)
FLASK_SECRET_KEY=change-me-in-production
